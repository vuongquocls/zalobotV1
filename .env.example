# Telegram Bot Token lay tu @BotFather
TG_TOKEN=1234567890:AAExxxxxxxxxxxxxxxxxxxxx

# Telegram supergroup ID, dang so am vi du -1001234567890
# Group phai bat Topics va bot phai la admin de tao/xoa/pin topic.
TG_GROUP_ID=-1001234567890

# File luu credential Zalo sau khi quet QR.
ZALO_CREDENTIALS_PATH=./credentials.json

# Thu muc luu mapping topic Zalo <-> Telegram.
DATA_DIR=./data

# Hermes Core dung chung. De trong thi bot fallback ve bridge Zalo <-> Telegram nhu cu.
HERMES_CORE_URL=http://127.0.0.1:8765
HERMES_CORE_TIMEOUT_MS=8000

# Alias de nhan dien khi nao tin nhom Zalo dang goi bot.
# Chat 1:1 Zalo luon duoc gui vao Hermes; nhom chi gui vao Hermes khi co alias.
ZALO_BOT_ALIASES=hermes,zalo bot,bot

# Neu de trong, moi nguoi trong Telegram approval group bam duyet duoc.
# Nen cau hinh ID Telegram cua anh khi van hanh that.
TG_APPROVER_USER_IDS=
TG_APPROVAL_GROUP_ID=
